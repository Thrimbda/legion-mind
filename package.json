{
  "name": "lgmind",
  "version": "0.3.1",
  "description": "Install, verify, rollback, and uninstall LegionMind assets for coding agents.",
  "private": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Thrimbda/legion-mind.git"
  },
  "bugs": {
    "url": "https://github.com/Thrimbda/legion-mind/issues"
  },
  "homepage": "https://github.com/Thrimbda/legion-mind#readme",
  "keywords": [
    "lgmind",
    "opencode",
    "legionmind",
    "agent",
    "workflow",
    "cli"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "bin": {
    "lgmind": "bin/lgmind.js",
    "setup-opencode": "bin/setup-opencode.js"
  },
  "files": [
    "bin/",
    "scripts/build-runtime-js.mjs",
    "scripts/lgmind.js",
    "scripts/setup-opencode.js",
    "scripts/setup-openclaw.js",
    "scripts/lib/setup-core.js",
    ".opencode/agents/",
    ".opencode/plugins/",
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:runtime-js": "node --no-warnings scripts/build-runtime-js.mjs",
    "prepack": "npm run build:runtime-js",
    "opencode:install": "node bin/setup-opencode.js install",
    "opencode:verify": "node bin/setup-opencode.js verify --strict",
    "opencode:rollback": "node bin/setup-opencode.js rollback",
    "opencode:uninstall": "node bin/setup-opencode.js uninstall",
    "opencode:help": "node bin/setup-opencode.js --help",
    "openclaw:install": "node --experimental-strip-types scripts/setup-openclaw.ts install",
    "openclaw:verify": "node --experimental-strip-types scripts/setup-openclaw.ts verify --strict",
    "openclaw:rollback": "node --experimental-strip-types scripts/setup-openclaw.ts rollback",
    "openclaw:uninstall": "node --experimental-strip-types scripts/setup-openclaw.ts uninstall",
    "scheduler:debug": "node --experimental-strip-types --experimental-sqlite scripts/linear-scheduler.ts",
    "test:linear-scheduler": "node --test --experimental-strip-types --experimental-sqlite tests/regression/linear-scheduler-core.test.ts",
    "pack:dry-run": "npm pack --dry-run --json",
    "test:regression": "node --test --experimental-strip-types --experimental-sqlite tests/regression/*.test.ts"
  },
  "engines": {
    "node": ">=22.6.0"
  }
}
