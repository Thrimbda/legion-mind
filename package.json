{
  "name": "legion-mind-opencode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "legion-mind-opencode": "scripts/setup-opencode.ts"
  },
  "scripts": {
    "opencode:install": "node scripts/setup-opencode.ts install",
    "opencode:verify": "node scripts/setup-opencode.ts verify --strict",
    "opencode:rollback": "node scripts/setup-opencode.ts rollback",
    "openclaw:install": "node --experimental-strip-types scripts/setup-openclaw.ts install",
    "openclaw:verify": "node --experimental-strip-types scripts/setup-openclaw.ts verify",
    "benchmark:preflight": "node --experimental-strip-types scripts/benchmark/preflight.ts",
    "benchmark:smoke": "node --experimental-strip-types scripts/benchmark/run.ts --mode smoke",
    "benchmark:full": "node --experimental-strip-types scripts/benchmark/run.ts --mode full",
    "benchmark:score": "node --experimental-strip-types scripts/benchmark/score.ts",
    "benchmark:report": "node --experimental-strip-types scripts/benchmark/report.ts"
  },
  "engines": {
    "node": ">=22.6.0"
  }
}
